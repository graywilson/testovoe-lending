# Пример переменных окружения. Скопируйте в .env и заполните значения:
#   cp .env.example .env
# В .env лежат реальные секреты, и он НЕ коммитится в git.

# ---------- Сервер ----------
PORT=41321
NODE_ENV=production

# ---------- SMTP (отправка писем). По умолчанию — Beget. ----------
# Порт 465 = SSL (secure=true); 587/25 = STARTTLS (secure=false).
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@mailmoment.ru
SMTP_PASS=ВАШ_SMTP_ПАРОЛЬ

# Кто в поле "От кого" и на какой ящик владельца падает уведомление о заявке.
MAIL_FROM_NAME=Вадим Искаков · Портфолио
MAIL_FROM_ADDRESS=info@mailmoment.ru
OWNER_EMAIL=graywilsonwise@gmail.com

# ---------- AI (Groq, OpenAI-совместимый API) ----------
GROQ_API_KEY=ВАШ_GROQ_API_KEY
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# CORS для dev (Vite dev-server). В проде не используется.
CORS_ORIGIN=http://localhost:5173
